{
  "name": "cara",
  "displayName": "Cara - Typing Analytics",
  "description": "Developer typing analytics and speed tracking for VS Code",
  "version": "0.0.1",
  "publisher": "cara",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "typing speed",
    "wpm",
    "productivity",
    "analytics",
    "typing test"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cara.startTypingTest",
        "title": "Cara: Start Typing Test"
      },
      {
        "command": "cara.resetTypingTest",
        "title": "Cara: Reset Typing Test"
      },
      {
        "command": "cara.showStats",
        "title": "Cara: Show Statistics"
      },
      {
        "command": "cara.showStatusBar",
        "title": "Cara: Show Status Bar"
      }
    ],
    "configuration": {
      "title": "Cara",
      "properties": {
        "cara.showSpeedInStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show typing speed in the status bar"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "bun run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/node": "22.x",
    "typescript-eslint": "^8.54.0",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3"
  }
}
